{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Bindars",
  "version": "1.2.1",
  "identifier": "dev.bindars.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Bindars",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self'; connect-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$TEMP/**"],
          "requireLiteralLeadingDot": true
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../LICENSE", "../THIRD-PARTY-NOTICES"],
    "category": "Utility",
    "shortDescription": "Read markdown beautifully",
    "longDescription": "Bindars is the reading app for markdown. Drop a file in, read it beautifully. Features Mermaid diagrams, LaTeX math, syntax-highlighted code blocks, GFM support, table of contents, four themes, and a keyboard-driven workflow. No cloud, no subscription.",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      },
      {
        "ext": ["fountain"],
        "mimeType": "text/x-fountain",
        "description": "Fountain Screenplay"
      }
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
